GPT_FS_MCP_HOST=127.0.0.1
GPT_FS_MCP_PORT=8789
GPT_FS_MCP_DEFAULT_CWD=
GPT_FS_MCP_SHELL_TIMEOUT_MS=120000
GPT_FS_MCP_MAX_BODY_BYTES=99999000
GPT_FS_MCP_MAX_BACKUP_BYTES=90000000
GPT_FS_MCP_MAX_OUTPUT_BYTES=90000000
GPT_FS_MCP_MAX_SCREENSHOT_AREA_PIXELS=33000000
GPT_FS_MCP_MAX_SCREENSHOT_BYTES=90000000
GPT_FS_MCP_MAX_SCREENSHOT_DIMENSION=8192
GPT_FS_MCP_MAX_SCREENSHOT_FILES=100
GPT_FS_MCP_BROWSER_SESSION_IDLE_MS=1800000
GPT_FS_MCP_MAX_BROWSER_LOG_ENTRIES=200
GPT_FS_MCP_MAX_BROWSER_SCREENSHOT_FILES=100
GPT_FS_MCP_MAX_BROWSER_SCREENSHOT_BYTES=90000000
GPT_FS_MCP_MAX_BROWSER_SESSIONS=5
GPT_FS_MCP_JOURNAL_PATH=.\data\journal.jsonl
GPT_FS_MCP_BACKUP_DIR=.\data\backups
GPT_FS_MCP_MAX_POLICY_MODE=destructive
GPT_FS_MCP_ENFORCE_WORKSPACE_PROFILES=true
GPT_FS_MCP_WORKSPACE_PROFILES_JSON=
GPT_FS_MCP_SHELL_POLICY=full
GPT_FS_MCP_PROCESS_POLICY=full
GPT_FS_MCP_UNTRUSTED_CONTENT_ROOTS=

NODE_ENV=development
AUTH_REQUIRED=true
DEV_IDENTITY_LOGIN=local-dev
DEFAULT_OAUTH_SCOPES=mcp:read mcp:write mcp:shell mcp:git mcp:patch mcp:delete mcp:process mcp:screen mcp:desktop mcp:browser
AUTH_REQUIRE_PKCE=true
AUTH_RATE_LIMIT_MAX=60
AUTH_RATE_LIMIT_MAX_BUCKETS=10000
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_STORE_MAX_PENDING=1000
AUTH_STORE_MAX_AUTH_CODES=1000
AUTH_STORE_MAX_TOKENS=100
AUTH_STORE_CLEANUP_INTERVAL_MS=60000
EXPOSE_RUNTIME_DEBUG=false
PUBLIC_BASE_URL=http://127.0.0.1:8789
CLOUDFLARE_TUNNEL_ENABLED=false
TRUST_PROXY_HEADERS=false
CLOUDFLARED_EXE=
CLOUDFLARED_CONFIG=
CLOUDFLARE_TUNNEL_NAME=chatgpt-local-agent-mcp

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ALLOWED_GITHUB_LOGINS=

OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URIS=
